# Токен от @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Время ежедневной рассылки (формат HH:MM, часовой пояс ниже)
DAILY_TIME=09:00
TIMEZONE=Europe/Moscow

# Telegram user id, которому не даём саркастичные комплименты (узнать: @userinfobot)
EXCLUDED_USER_ID=

# Прокси для Telegram API (как в старом боте: socks5://127.0.0.1:10808)
PROXY_URL=socks5://127.0.0.1:10808

# Таймауты подключения к Telegram API (секунды)
CONNECT_TIMEOUT=30
READ_TIMEOUT=30
