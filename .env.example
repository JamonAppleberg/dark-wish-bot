# Токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Время ежедневной рассылки
DAILY_TIME=09:00
TIMEZONE=Europe/Moscow

# Telegram user id без саркастичных комплиментов (@userinfobot)
EXCLUDED_USER_ID=

# SOCKS5-прокси (как в старом боте)
PROXY_URL=socks5://127.0.0.1:10808

# Таймауты Telegram API (секунды)
CONNECT_TIMEOUT=30
READ_TIMEOUT=30
